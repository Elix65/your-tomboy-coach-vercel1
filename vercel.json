{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/widget",
      "destination": "/widget/index.html"
    },
    {
      "source": "/widget/",
      "destination": "/widget/index.html"
    },
    {
      "source": "/widget/(.*)",
      "destination": "/widget/$1"
    },
    {
      "source": "/",
