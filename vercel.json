    {
      "source": "/api/overlay/link/start",
      "destination": "/api/router?action=overlay-link-start"
    },
    {
      "source": "/api/overlay/link/exchange",
      "destination": "/api/router?action=overlay-link-exchange"
    },
    {
      "source": "/api/overlay/token/refresh",
