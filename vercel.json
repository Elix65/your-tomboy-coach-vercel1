    {
      "source": "/overlay/connect",
      "destination": "/overlay-connect.html"
    },
    {
      "source": "/api/yumiko",
      "destination": "/api/router?action=yumiko"
    },
    {
      "source": "/api/regenerate-last",
      "destination": "/api/router?action=regenerate-last"
    },
    {
      "source": "/api/reset-chat",
      "destination": "/api/router?action=reset-chat"
    },
    {
      "source": "/api/get-messages",
      "destination": "/api/router?action=get-messages"
    },
    {
      "source": "/api/set-active-skin",
      "destination": "/api/router?action=set-active-skin"
    },
    {
      "source": "/api/get-active-skin",
      "destination": "/api/router?action=get-active-skin"
    },
    {
      "source": "/api/inventario",
      "destination": "/api/router?action=inventario"
    },
    {
      "source": "/api/gacha-pull",
      "destination": "/api/router?action=gacha-pull"
