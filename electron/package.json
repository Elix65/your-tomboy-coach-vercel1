{
  "name": "yumiko-overlay-electron",
  "version": "1.0.0",
  "description": "Desktop overlay for Yumiko 100% built with Electron.",
  "author": "Elix65",
  "homepage": "https://github.com/Elix65/your-tomboy-coach-vercel1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elix65/your-tomboy-coach-vercel1.git"
  },
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.21moon.yumikooverlay",
    "productName": "YumikoOverlay",
    "asar": true,
    "files": [
      "main.js",
      "preload.js"
    ],
    "protocols": [
      {
        "name": "Yumiko Protocol",
        "schemes": [
          "yumiko"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "artifactName": "Yumiko-Overlay-Setup.exe"
    },
    "zip": {
      "artifactName": "Yumiko-Overlay-Windows.zip"
    }
  }
}
